generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  designs   Design[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Design {
  id          String       @id @default(cuid())
  prompt      String
  style       String       @default("realistic")
  imageUrl    String?
  status      DesignStatus @default(PENDING)
  jobId       String?
  width       Int          @default(512)
  height      Int          @default(512)
  title       String?
  tags        String[]
  source      String       @default("generated")
  user        User         @relation(fields: [userId], references: [id])
  userId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum DesignStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
