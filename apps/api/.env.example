DATABASE_URL="postgresql://postgres:password@localhost:5432/textile_ai?schema=public"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"
FASTAPI_URL="http://localhost:8000"
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Security
CORS_ORIGINS=http://localhost:3000
HELMET_ENABLED=true

# Server
PORT=3001
NODE_ENV=development
