# =============================================================================
# Textile AI Platform - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_postgres_password
POSTGRES_DB=textile_ai

# Full connection URL (used by API and AI services)
DATABASE_URL=postgresql://postgres:your_secure_postgres_password@postgres:5432/textile_ai

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your_secure_redis_password
REDIS_URL=redis://:your_secure_redis_password@redis:6379

# -----------------------------------------------------------------------------
# JWT / Auth (API service)
# -----------------------------------------------------------------------------
JWT_SECRET=your_very_long_and_secure_jwt_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# AI Service
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
HF_TOKEN=hf_...

# -----------------------------------------------------------------------------
# Next.js Frontend (public vars exposed to the browser)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Service ports (optional overrides)
# -----------------------------------------------------------------------------
WEB_PORT=3000
API_PORT=3001
AI_PORT=8000
